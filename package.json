{
  "name": "ldaplite",
  "version": "0.15.0",
  "description": "Lightweight LDAP server with web UI",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config internal/web/frontend/vite.config.ts --host 127.0.0.1",
    "build": "tsc -b internal/web/frontend/tsconfig.json && vite build --config internal/web/frontend/vite.config.ts",
    "build:css": "npm run build",
    "watch:css": "vite --config internal/web/frontend/vite.config.ts --host 127.0.0.1",
    "typecheck": "tsc -b internal/web/frontend/tsconfig.json"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.1.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  },
  "license": "MIT"
}
